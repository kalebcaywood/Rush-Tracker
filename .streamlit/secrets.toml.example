# Copy this file to .streamlit/secrets.toml (gitignored) and fill in real values.
# Find these in your Supabase project: Settings > API.
#   SUPABASE_URL          -> "Project URL"
#   SUPABASE_SERVICE_KEY  -> "service_role" secret key (NOT the anon/public key —
#                             this app relies on the service role to read/write
#                             all tables server-side; never expose it to a browser).

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY = "your-service-role-key"
